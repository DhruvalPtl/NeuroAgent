# Virtual environment
venv/

# Isolated external tool environments (not committed — see BLOCKERS.md for each)
external/canya_env/

# Python cache
__pycache__/
*.pyc

# Raw and processed data (keep .gitkeep)
data/raw/*
data/processed/*
!data/raw/.gitkeep

# Large local external/lab data files — referenced by path in
# config/external_sources.yaml and the lab data loader, not committed.
# Same convention as data/raw/* exclusion from Step 0.
data/CPAD/
data/waltzdb_export.csv
data/Data for different peptide sequences.xlsx
!data/processed/.gitkeep
!data/raw/alpha_synuclein/.gitkeep
!data/raw/tau/.gitkeep
!data/raw/tdp43/.gitkeep
!data/raw/tmem/.gitkeep

# Environment variables
.env

# Database files
*.db

# Jupyter checkpoints
.ipynb_checkpoints/

# NeuroAgent runtime state — ephemeral, per-process, never commit
platform_core/.budget_state.json
platform_core/.checkpoint_state.json
platform_core/.staging/
